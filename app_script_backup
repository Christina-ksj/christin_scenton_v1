  .badge { background: #e0f2fe; color: #0369a1; padding: 2px 8px; border-radius: 99px; font-weight: 600; }
  .badge.green { background: #dcfce7; color: #15803d; }
  textarea { width: 100%; height: 180px; font-family: monospace; font-size: 11px;
    border: 1px solid #e2e8f0; border-radius: 6px; padding: 10px;
    background: #fff; resize: none; }
  .btn { margin-top: 10px; padding: 8px 18px; background: #3b82f6; color: #fff;
    border: none; border-radius: 6px; cursor: pointer; font-size: 13px; font-weight: 600; }
  .btn:hover { background: #2563eb; }
  .step { margin-top: 14px; background: #fff; border: 1px solid #e2e8f0;
    border-radius: 8px; padding: 12px 14px; }
  .step-title { font-size: 11px; font-weight: 700; color: #64748b;
    text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; }
  .cmd { background: #1e293b; color: #7dd3fc; font-family: monospace; font-size: 11px;
    padding: 8px 12px; border-radius: 6px; word-break: break-all; cursor: pointer; }
  .cmd:hover { background: #334155; }
  .tip { font-size: 11px; color: #94a3b8; margin-top: 6px; }
</style>
</head>
<body>
  <h3>📋 GSC 데이터 JSON 내보내기</h3>
  <div class="meta">
    <span class="badge green">📅 ${startDate} ~ ${endDate}</span>
    <span class="badge">${totalDays}일</span>
    <span class="badge">클릭 ${totalClicks.toLocaleString()}회</span>
    <span class="badge">키워드 ${keywords.length}개</span>
  </div>

  <textarea id="json" readonly>${jsonStr.replace(/</g, "&lt;").replace(/>/g, "&gt;")}</textarea>
  <button class="btn" onclick="copyJson()">📋 JSON 복사</button>

  <div class="step">
    <div class="step-title">🖥 터미널에서 실행 (복사 후)</div>
    <div class="cmd" onclick="copyCmd(this)">${cmd}</div>
    <div class="tip">↑ 클릭하면 명령어도 복사됩니다</div>
  </div>

<script>
  document.getElementById("json").select();
  function copyJson() {
    const t = document.getElementById("json");
    t.select();
    document.execCommand("copy");
    event.target.textContent = "✅ JSON 복사됨!";
    setTimeout(() => event.target.textContent = "📋 JSON 복사", 2000);
  }
  function copyCmd(el) {
    const ta = document.createElement("textarea");
    ta.value = el.textContent;
    document.body.appendChild(ta);
    ta.select();
    document.execCommand("copy");
    document.body.removeChild(ta);
    el.style.background = "#064e3b";
