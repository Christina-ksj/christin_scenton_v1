function sendToDashboard() {
  const GITHUB_TOKEN = "여기에_새_GitHub_PAT";
  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);

  function getSheetDataLocal(sheetName) {
    const sheet = ss.getSheetByName(sheetName);
    if (!sheet) return null;
    const data = sheet.getDataRange().getValues();
    if (data.length < 2) return null;
    const headers = data[0];
    return data.slice(1).map(row => {
      let obj = {};
      headers.forEach((h, i) => obj[h] = row[i]);
      return obj;
    });
  }

  const chart   = getSheetDataLocal("차트");
  const queries = getSheetDataLocal("검색어 수");
  const pages   = getSheetDataLocal("페이지");
  const country = getSheetDataLocal("국가");

  const shaResponse = UrlFetchApp.fetch(
    "https://api.github.com/repos/Christina-ksj/christin_scenton_v1/contents/index.html",
    { method: "GET", headers: { "Authorization": "Bearer " + GITHUB_TOKEN }, muteHttpExceptions: true }
  );
  let githubSha = "";
  if (shaResponse.getResponseCode() === 200) {
    githubSha = JSON.parse(shaResponse.getContentText()).sha;
  }

  const prompt = `센트온(Scenton) 서치콘솔 데이터로 인터랙티브 HTML 대시보드 생성.\n차트: ${JSON.stringify(chart)}\n키워드: ${JSON.stringify(queries)}\n페이지: ${JSON.stringify(pages)}\n국가: ${JSON.stringify(country)}\nHTML만 출력.`;

  UrlFetchApp.fetch(WEBHOOK_URL, {
    method: "POST",
    contentType: "application/json",
    payload: JSON.stringify({ githubToken: GITHUB_TOKEN, githubSha, prompt })
  });
  SpreadsheetApp.getUi().alert("✅ 대시보드 생성 요청 완료!\n약 30~60초 후 GitHub Pages에 반영돼요.");
}

