function exportToLocalJSON() {
  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);

  // 차트
  const chart = getSheetData(ss, "차트").map(row => {
    const dateK  = findKey(row, ["날짜", "date"]);
    const clickK = findKey(row, ["클릭", "click"]);
    const impK   = findKey(row, ["노출", "impress"]);
    const ctrK   = findKey(row, ["CTR", "ctr"]);
    const posK   = findKey(row, ["순위", "position"]);
    return {
      "날짜":  formatDate(row[dateK]),
      "클릭수": parseInt(row[clickK]) || 0,
      "노출":   parseInt(row[impK])   || 0,
      "CTR":   normCTR(row[ctrK]),
      "순위":  parseFloat(row[posK]) || 0
    };
  }).filter(r => r["날짜"]).sort((a, b) => a["날짜"].localeCompare(b["날짜"]));

  // 키워드
  const keywords = getSheetData(ss, "검색어 수").map(row => {
    const kwK    = findKey(row, ["검색어", "쿼리", "키워드", "query", "keyword"]);
    const clickK = findKey(row, ["클릭", "click"]);
    const impK   = findKey(row, ["노출", "impress"]);
    const ctrK   = findKey(row, ["CTR", "ctr"]);
    const posK   = findKey(row, ["순위", "position"]);
    return {
      "인기 검색어": String(row[kwK] || "").trim(),
      "클릭수":     parseInt(row[clickK]) || 0,
      "노출":        parseInt(row[impK])   || 0,
      "CTR":        normCTR(row[ctrK]),
      "게재 순위":  parseFloat(row[posK]) || 0
    };
  }).filter(r => r["인기 검색어"]);

  // 페이지
  const pages = getSheetData(ss, "페이지").map(row => {
    const pageK  = findKey(row, ["페이지", "url", "page"]);
    const clickK = findKey(row, ["클릭", "click"]);
    const impK   = findKey(row, ["노출", "impress"]);
    const ctrK   = findKey(row, ["CTR", "ctr"]);
    const posK   = findKey(row, ["순위", "position"]);
    return {
      "인기 페이지": String(row[pageK] || "").trim(),
      "클릭수":     parseInt(row[clickK]) || 0,
      "노출":        parseInt(row[impK])   || 0,
      "CTR":        normCTR(row[ctrK]),
      "게재 순위":  parseFloat(row[posK]) || 0
    };
  }).filter(r => r["인기 페이지"]);

  // 국가
  const countries = getSheetData(ss, "국가").map(row => {
    const countryK = findKey(row, ["국가", "country"]);
    const clickK   = findKey(row, ["클릭", "click"]);
    const impK     = findKey(row, ["노출", "impress"]);
    return {
      "국가":  String(row[countryK] || "").trim(),
      "클릭수": parseInt(row[clickK]) || 0,
      "노출":   parseInt(row[impK])   || 0
    };
  }).filter(r => r["국가"]);

  // 날짜 범위 (차트에서 자동 추출)
  const dates     = chart.map(r => r["날짜"]).filter(Boolean);
  const startDate = dates[0]              || "";
  const endDate   = dates[dates.length-1] || "";
  const today     = formatDate(new Date());

  // 기회 키워드 (순위 11~20, 노출 높음)
  const opportunity = keywords
    .filter(k => k["게재 순위"] > 10 && k["게재 순위"] <= 20 && k["노출"] > 50)
    .sort((a, b) => b["노출"] - a["노출"])
    .slice(0, 10);

  // 저CTR 키워드
  const low_ctr = keywords
    .filter(k => k["노출"] >= 200 && k["CTR"] < 0.01)
    .sort((a, b) => b["노출"] - a["노출"])
    .slice(0, 10);

  const gscData = {
    chart,
    keywords,
    pages,
    devices:     [],   // 기기 시트 없으면 빈 배열 → inject_data.py가 기존값 유지
    countries,
    index:       null, // 색인 시트 없으면 null → inject_data.py가 기존값 유지
    opportunity,
    low_ctr
  };

  const jsonStr   = JSON.stringify(gscData, null, 2);
  const totalDays = chart.length;
  const totalClicks = chart.reduce((s, r) => s + r["클릭수"], 0);

  // 터미널 명령어
  const cmd = `pbpaste > ~/AI-S/scenton/data/gsc_data.json && make -C ~/AI-S/scenton update`;

  const html = HtmlService.createHtmlOutput(`<!DOCTYPE html>
